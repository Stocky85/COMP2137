#!/bin/bash

cat << EOF

# Introudction to script.
echo
echo "System Report For $(hostname) Generated By $(whoami), On $(date)"
echo

# System  information title.
echo "System Information"
echo "----------------------"
echo

# OS line.
echo "OS: $(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '\"')"

# Uptime line.
echo "Uptime: $(uptime -p)"

# CPU line.
echo "CPU: $(lscpu | grep  'Model name' | cut -d':' -f2 | xargs)"

# RAM line.
echo "RAM: $(free -h | awk '/Mem:/ {print $2}')"

# Video Card line.
echo "Video Card: $(lshw -class display 2>/dev/null | grep product | head -1 | cut -d':' -f2 | xargs)"

# Disk line.
echo "Disk(s): $(lsblk -dn -o NAME,SIZE | grep '^sda' | xargs)"

# Interface command used for the host address.
interface=$(ip route | awk '/default/ {print $5}')

# Host Address line.
echo "Host Address: $(ip -4 addr show $interface | awk '/inet / {print $2}' | cut -d'/' -f1)"

# Gateway IP line.
echo "Gateway IP: $(ip route | awk '/default/ {print $3}')"

# DNS Server line.
echo "DNS Server: $(grep nameserver /etc/resolv.conf | awk '{print $2}' | head -1)"

# System status title.
echo
echo "System Status"
echo "-----------------"
echo

# Users logged In line.
echo "Users Logged In: $(who | awk '{print $1}' | sort -u | paste -sd ',' -)"

# Disk Space line.
echo "Disk Space: $(df -h | awk '$1 ~ /^\/dev\// {print $6, $4}' | paste -sd ', ' -)"

# Process Count line.
echo "Process Count: $(ps -e --no-headers | wc -l)"

# Load Averages line.
echo "Load Averages: $(uptime | awk -F'load average:' '{print $2}' | xargs)"

# Listening Network Ports line.
echo "Listening Network Ports: $(ss -tuln | awk 'NR>1 {print $5}' | cut -d':' -f2 | grep -E '^[0-9]+' | sort -u | paste -sd ', ' -)"

# UFW Status line.
echo "UFW Status: $(sudo ufw status | head -1)"

echo
